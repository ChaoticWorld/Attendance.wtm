@page "/Report/ReportScript"
@using em_wtm.ViewModel.Report.ReportScriptVMs;
@inherits BasePage
@attribute [ActionDescription("报表脚本", "em_wtm.Controllers,ReportScript")]
<div class="@hiddenWTSearchPanel">
<WTSearchPanel OnSearch="@DoSearch">
    <ValidateForm Model="@SearchModel">
        <Row ItemsPerRow="ItemsPerRow.Three" RowType="RowType.Inline">
            <Select @bind-Value="@SearchModel.ReportId" IsDisabled="@isDisabled" Items="@AllReportMains" PlaceHolder="@WtmBlazor.Localizer["Sys.All"]"/>
        </Row>
    </ValidateForm>
</WTSearchPanel>
</div>


<Table @ref="dataTable" TItem="ReportScript_View" OnClickRowCallback="OnClickRow" OnQueryAsync="OnSearch" IsPagination="true" IsStriped="true" IsBordered="true" ShowRefresh="false"
       ShowToolbar="true" IsMultipleSelect="true" ShowExtendButtons="true" ShowDefaultButtons="false" ShowExtendEditButton="false" ShowExtendDeleteButton="false" style="margin-top:10px;">
    <TableColumns>

        <TableColumn @bind-Field="@context.Name_view"  />
        <TableColumn @bind-Field="@context.Script"  />
        <TableColumn @bind-Field="@context.Name_view2"  />
        <TableColumn @bind-Field="@context.ScriptOrder"  />
    </TableColumns>
    <TableToolbarTemplate>
        @if (IsAccessable("/api/ReportScript/Add"))
        {
            <TableToolbarButton TItem="ReportScript_View" Color="Color.Primary" Icon="fa fa-fw fa-plus" Text="@WtmBlazor.Localizer["Sys.Create"]" OnClickCallback="OnCreateClick" />
        }
        @if (IsAccessable("/api/ReportScript/BatchDelete"))
        {
            <TableToolbarPopconfirmButton TItem="ReportScript_View" Color="Color.Primary"
                                          Icon="fa fa-fw fa-trash" Text="@WtmBlazor.Localizer["Sys.BatchDelete"]"
                                          OnConfirm="@OnBatchDeleteClick" Content="@WtmBlazor.Localizer["Sys.BatchDeleteConfirm"]" CloseButtonText="@WtmBlazor.Localizer["Sys.Close"]"
                                          ConfirmButtonText="@WtmBlazor.Localizer["Sys.BatchDelete"]" ConfirmButtonColor="Color.Danger" />
        }
        
        @if (IsAccessable("/api/ReportScript/Import"))
        {
            <TableToolbarButton TItem="ReportScript_View" Color="Color.Primary" Icon="fa fa-fw fa-upload" Text="@WtmBlazor.Localizer["Sys.Import"]" OnClickCallback="@OnImportClick" />
        }
        @if (IsAccessable("/api/ReportScript/ExportExcel"))
        {
            <TableToolbarButton TItem="ReportScript_View" Color="Color.Primary" Icon="fa fa-fw fa-download" Text="@WtmBlazor.Localizer["Sys.Export"]" OnClickCallback="@OnExportClick" IsAsync="true" />
        }
    </TableToolbarTemplate>
    <RowButtonTemplate>
        <div style="padding-right:10px;">
            @if (IsAccessable("/api/ReportScript/Edit"))
            {
                <TableCellButton Size="Size.ExtraSmall" Color="Color.Success" Icon="fa fa-edit" Text="@WtmBlazor.Localizer["Sys.Edit"]" OnClick="() => OnEditClick(context)" />
            }
            @if (IsAccessable("/api/ReportScript/{id}"))
            {
                <TableCellButton Size="Size.ExtraSmall" Color="Color.Info" Icon="fa fa-info" Text="@WtmBlazor.Localizer["Sys.Details"]" OnClick="()=>OnDetailsClick(context)" />
            }
            @if (IsAccessable("/api/ReportScript/BatchDelete"))
            {
                <PopConfirmButton Icon="fa fa-trash" Text="@WtmBlazor.Localizer["Sys.Delete"]" OnConfirm="() => OnDeleteClick(context)" Color="Color.Danger" Size="Size.ExtraSmall"
                                  Content="@WtmBlazor.Localizer["Sys.DeleteConfirm"]" CloseButtonText="@WtmBlazor.Localizer["Sys.Close"]" ConfirmButtonText="@WtmBlazor.Localizer["Sys.Delete"]" ConfirmButtonColor="Color.Danger" />
            }
        </div>
    </RowButtonTemplate>
</Table>
<em_wtm.Shared.Pages.Report.ReportScriptParam.Index hiddenWTSearchPanel="hiddenWTSearchPanel" showToolBar=false ScriptID="@scriptID" />

@code{

    [Parameter]
    public string hiddenWTSearchPanel { get; set; }
    [Parameter]
    public int ReportID{ get; set; }

    private int scriptID{ get; set; }
    private List<ReportScript_View> SelectedItems { get; set; }

    private ReportScriptSearcher SearchModel = new ReportScriptSearcher();
    private Table<ReportScript_View> dataTable;

    private List<SelectedItem> AllReportMains = new List<SelectedItem>();
    private bool isDisabled = false;

    protected override async Task OnInitializedAsync()
    {

        AllReportMains = await WtmBlazor.Api.CallItemsApi("/api/ReportScript/GetReportMains", placeholder: WtmBlazor.Localizer["Sys.All"]);

        await base.OnInitializedAsync();
    }

    private async Task<QueryData<ReportScript_View>> OnSearch(QueryPageOptions opts)
    {
        if (ReportID > 0)
        {
            SearchModel.ReportId = ReportID;
            isDisabled = ReportID > 0;
        }
        return await StartSearch<ReportScript_View>("/api/ReportScript/Search", SearchModel, opts);
    }

    private void DoSearch()
    {
        dataTable.QueryAsync();
    }

    private async Task OnCreateClick(IEnumerable<ReportScript_View> items)
    {
        if (await OpenDialog<Create>(WtmBlazor.Localizer["Sys.Create"],x=>x.ReportID == ReportID) == DialogResult.Yes)
        {
            await dataTable.QueryAsync();
        }
    }

    private async Task OnEditClick(ReportScript_View item)
    {
        if (await OpenDialog<Edit>(WtmBlazor.Localizer["Sys.Edit"], x => x.id == item.ID) == DialogResult.Yes)
        {
            await dataTable.QueryAsync();
        }
    }

    private async Task OnDetailsClick(ReportScript_View item)
    {
        await OpenDialog<Details>(WtmBlazor.Localizer["Sys.Details"], x => x.id == item.ID.ToString());
    }

    private async Task OnBatchDeleteClick()
    {
        if (dataTable.SelectedRows?.Any() == true)
        {
            await PostsData(dataTable.SelectedRows.Select(x => x.ID).ToList(), $"/api/ReportScript/batchdelete", (s) => WtmBlazor.Localizer["Sys.BatchDeleteSuccess", s]);
            await dataTable.QueryAsync();
        }
        else
        {
            await WtmBlazor.Toast.Information(WtmBlazor.Localizer["Sys.Info"], WtmBlazor.Localizer["Sys.SelectOneRowMin"]);
        }
    }

    private async Task OnDeleteClick(ReportScript_View item)
    {
        await PostsData(new List<string> { item.ID.ToString() }, $"/api/ReportScript/batchdelete", (s) => "Sys.OprationSuccess");
        await dataTable.QueryAsync();
    }


    private async Task OnExportClick(IEnumerable<ReportScript_View> items)
    {
        if (dataTable.SelectedRows?.Any() == true)
        {
            await Download("/api/ReportScript/ExportExcelByIds", dataTable.SelectedRows.Select(x => x.ID.ToString()).ToList());
        }
        else
        {
            await Download("/api/ReportScript/ExportExcel", SearchModel);
        }
    }
    private async Task OnImportClick(IEnumerable<ReportScript_View> items)
    {
        if (await OpenDialog<Import>(WtmBlazor.Localizer["Sys.Import"]) == DialogResult.Yes)
        {
            await dataTable.QueryAsync();
        }
    }
    private  Task OnClickRow(ReportScript_View script) {
        scriptID = script.ID;
        //StateHasChanged();
        return Task.CompletedTask;
    }

}
