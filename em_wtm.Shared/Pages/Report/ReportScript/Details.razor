@page "/Report/ReportScript/Details/{id}"
@using em_wtm.ViewModel.Report.ReportScriptVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" >
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">

            <Display @bind-Value="@Model.Entity.ReportID" Lookup="@AllReportMains"  ShowLabel="true"/>
            <Display @bind-Value="@Model.Entity.Script"   ShowLabel="true"/>
            <Display @bind-Value="@Model.Entity.ScriptTypeId" Lookup="@AllReportScriptTypeEnums"  ShowLabel="true"/>
            <Display @bind-Value="@Model.Entity.ScriptOrder"   ShowLabel="true"/>
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Primary" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
    </div>
</ValidateForm>

@code {

    private ReportScriptVM Model = null;
    private ValidateForm vform { get; set; }
    [Parameter]
    public string id { get; set; }

    private List<SelectedItem> AllReportMains = new List<SelectedItem>();

    private List<SelectedItem> AllReportScriptTypeEnums = new List<SelectedItem>();


    protected override async Task OnInitializedAsync()
    {

        AllReportMains = await WtmBlazor.Api.CallItemsApi("/api/ReportScript/GetReportMains", placeholder: WtmBlazor.Localizer["Sys.All"]);

        AllReportScriptTypeEnums = await WtmBlazor.Api.CallItemsApi("/api/ReportScript/GetReportScriptTypeEnums", placeholder: WtmBlazor.Localizer["Sys.All"]);

        var rv = await WtmBlazor.Api.CallAPI<ReportScriptVM>($"/api/ReportScript/{id}");
        Model = rv.Data;
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
