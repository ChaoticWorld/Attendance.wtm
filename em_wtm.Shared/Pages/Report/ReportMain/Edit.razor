@page "/Report/ReportMain/Edit/{id}"
@using em_wtm.ViewModel.Report.ReportMainVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit">
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Inline">
        <BootstrapInput @bind-Value="@Model.Entity.Description"  />
        <BootstrapInput @bind-Value="@Model.Entity.Name"  />
        <BootstrapInput @bind-Value="@Model.Entity.Title"  />
        <Select @bind-Value="@Model.Entity.DBConnection" DisplayText="数据链接" Items="@AllDbConnection" PlaceHolder="@WtmBlazor.Localizer["Sys.PleaseSelect"]" />
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Primary" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
        <Button Color="Color.Primary" ButtonType="ButtonType.Submit" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Edit"]" IsAsync="true" />
    </div>
</ValidateForm>

@code {

    private ReportMainVM Model = null;
    private ValidateForm vform { get; set; }
    [Parameter]
    public int id { get; set; }


    private List<SelectedItem> AllDbConnection = new List<SelectedItem>();

    protected override async Task OnInitializedAsync() {
        AllDbConnection = await WtmBlazor.Api.CallItemsApi("/api/ReportMain/GetReportDBConnections", placeholder: WtmBlazor.Localizer["Sys.PleaseSelect"]);

        var rv = await WtmBlazor.Api.CallAPI<ReportMainVM>($"/api/ReportMain/{id}");
        Model = rv.Data;
        await base.OnInitializedAsync();
   }

    private async Task Submit(EditContext context)
    {
        await PostsForm(vform, $"/api/ReportMain/edit", (s) => "Sys.OprationSuccess", method: HttpMethodEnum.PUT);
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
