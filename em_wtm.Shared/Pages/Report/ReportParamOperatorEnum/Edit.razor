@page "/Report/ReportParamOperatorEnum/Edit/{id}"
@using em_wtm.ViewModel.Report.ReportParamOperatorEnumVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit">
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">

            <BootstrapInput @bind-Value="@Model.Entity.Operator"  />
            <BootstrapInput @bind-Value="@Model.Entity.OperatorTips"  />
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Primary" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
        <Button Color="Color.Primary" ButtonType="ButtonType.Submit" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Edit"]" IsAsync="true" />
    </div>
</ValidateForm>

@code {

    private ReportParamOperatorEnumVM Model = null;
    private ValidateForm vform { get; set; }
    [Parameter]
    public string id { get; set; }


    protected override async Task OnInitializedAsync()
    {
        var rv = await WtmBlazor.Api.CallAPI<ReportParamOperatorEnumVM>($"/api/ReportParamOperatorEnum/{id}");
        Model = rv.Data;
        await base.OnInitializedAsync();
    }

    private async Task Submit(EditContext context) {
        await PostsForm(vform, $"/api/ReportParamOperatorEnum/edit", (s) => "Sys.OprationSuccess", method: HttpMethodEnum.PUT);
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
