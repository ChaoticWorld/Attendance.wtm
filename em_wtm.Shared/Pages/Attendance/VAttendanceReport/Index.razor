    private async Task<bool> IsAttendanceManageRole() {
        if (IsAccessable("/api/VAttendanceReport/IsAttendanceManageRole"))
        {
            try
            {
                var hasAttendanceManageRole = await WtmBlazor.Api.CallAPI("/api/VAttendanceReport/IsAttendanceManageRole");
                return bool.Parse(hasAttendanceManageRole.Data);
            } catch { return false; }
        }
        else
            return false;
    }
