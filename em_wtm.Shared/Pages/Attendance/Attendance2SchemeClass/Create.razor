@page "/Attendance/Attendance2SchemeClass/Create"
@using em_wtm.ViewModel.Attendance.Attendance2SchemeClassVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit">
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">

            <BootstrapInput @bind-Value="@Model.Entity.ClassName"  />
            <BootstrapInputNumber @bind-Value="@Model.Entity.Periods"  />
            <BootstrapInput @bind-Value="@Model.Entity.ClassDescription"  />
            <BootstrapInputNumber @bind-Value="@Model.Entity.ClassPeriods"  />
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Secondary" Icon="fa fa-close" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
        <Button Color="Color.Primary" ButtonType="ButtonType.Submit" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Create"]" IsAsync="true" />
    </div>
</ValidateForm>

@code {

    private Attendance2SchemeClassVM Model = new Attendance2SchemeClassVM();
    private ValidateForm vform { get; set; }


    protected override async Task OnInitializedAsync()
    {

        await base.OnInitializedAsync();
    }


    private async Task Submit(EditContext context)
    {
        await PostsForm(vform, "/api/Attendance2SchemeClass/add", (s) => "Sys.OprationSuccess");
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
