@page "/Attendance/Attendance2Holiday/Create"
@using em_wtm.ViewModel.Attendance.Attendance2HolidayVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit">
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">

            <BootstrapInputNumber @bind-Value="@Model.Entity.IYear"  />
            <DateTimePicker @bind-Value="@Model.Entity.SDate"  />
            <BootstrapInput @bind-Value="@Model.Entity.SName"  />
            <BootstrapInput @bind-Value="@Model.Entity.SDescription"  />
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Secondary" Icon="fa fa-close" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
        <Button Color="Color.Primary" ButtonType="ButtonType.Submit" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Create"]" IsAsync="true" />
    </div>
</ValidateForm>

@code {

    private Attendance2HolidayVM Model = new Attendance2HolidayVM();
    private ValidateForm vform { get; set; }


    protected override async Task OnInitializedAsync()
    {

        await base.OnInitializedAsync();
    }


    private async Task Submit(EditContext context)
    {
        await PostsForm(vform, "/api/Attendance2Holiday/add", (s) => "Sys.OprationSuccess");
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
