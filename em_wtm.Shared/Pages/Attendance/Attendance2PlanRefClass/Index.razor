@page "/Attendance/Attendance2PlanRefClass"
@using em_wtm.ViewModel.Attendance.Attendance2PlanRefClassVMs;
@inherits BasePage
@attribute [ActionDescription("计划关联班次", "em_wtm.Controllers,Attendance2PlanRefClass")]

<WTSearchPanel OnSearch="@DoSearch">
    <ValidateForm Model="@SearchModel">
        <Row ItemsPerRow="ItemsPerRow.Three" RowType="RowType.Inline">

            <Select @bind-Value="@SearchModel.ClassId" Items="@AllAttendance2SchemeClasss" PlaceHolder="@WtmBlazor.Localizer["Sys.All"]"/>
            <Select @bind-Value="@SearchModel.PlanId" Items="@AllAttendance2PlanTimes" PlaceHolder="@WtmBlazor.Localizer["Sys.All"]"/>
        </Row>
    </ValidateForm>
</WTSearchPanel>



<Table @ref="dataTable" TItem="Attendance2PlanRefClass_View" OnQueryAsync="OnSearch" IsPagination="true" IsStriped="true" IsBordered="true" ShowRefresh="false"
       ShowToolbar="true" IsMultipleSelect="true" ShowExtendButtons="true" ShowDefaultButtons="false" ShowExtendEditButton="false" ShowExtendDeleteButton="false" style="margin-top:10px;">
    <TableColumns>

        <TableColumn @bind-Field="@context.ID"  />
        <TableColumn @bind-Field="@context.ClassName_view"  />
        <TableColumn @bind-Field="@context.PlanName_view"  />
        <TableColumn @bind-Field="@context.PeriodNo"  />
    </TableColumns>
    <TableToolbarTemplate>
        @if (IsAccessable("/api/Attendance2PlanRefClass/Add"))
        {
            <TableToolbarButton TItem="Attendance2PlanRefClass_View" Color="Color.Primary" Icon="fa fa-fw fa-plus" Text="@WtmBlazor.Localizer["Sys.Create"]" OnClickCallback="OnCreateClick" />
        }
        @if (IsAccessable("/api/Attendance2PlanRefClass/BatchDelete"))
        {
            <TableToolbarPopconfirmButton TItem="Attendance2PlanRefClass_View" Color="Color.Primary"
                                          Icon="fa fa-fw fa-trash" Text="@WtmBlazor.Localizer["Sys.BatchDelete"]"
                                          OnConfirm="@OnBatchDeleteClick" Content="@WtmBlazor.Localizer["Sys.BatchDeleteConfirm"]" CloseButtonText="@WtmBlazor.Localizer["Sys.Close"]"
                                          ConfirmButtonText="@WtmBlazor.Localizer["Sys.BatchDelete"]" ConfirmButtonColor="Color.Danger" />
        }
        
        @if (IsAccessable("/api/Attendance2PlanRefClass/Import"))
        {
            <TableToolbarButton TItem="Attendance2PlanRefClass_View" Color="Color.Primary" Icon="fa fa-fw fa-upload" Text="@WtmBlazor.Localizer["Sys.Import"]" OnClickCallback="@OnImportClick" />
        }
        @if (IsAccessable("/api/Attendance2PlanRefClass/ExportExcel"))
        {
            <TableToolbarButton TItem="Attendance2PlanRefClass_View" Color="Color.Primary" Icon="fa fa-fw fa-download" Text="@WtmBlazor.Localizer["Sys.Export"]" OnClickCallback="@OnExportClick" IsAsync="true" />
        }
    </TableToolbarTemplate>
    <RowButtonTemplate>
        <div style="padding-right:10px;">
            @if (IsAccessable("/api/Attendance2PlanRefClass/Edit"))
            {
                <TableCellButton Size="Size.ExtraSmall" Color="Color.Success" Icon="fa fa-edit" Text="@WtmBlazor.Localizer["Sys.Edit"]" OnClick="() => OnEditClick(context)" />
            }
            @if (IsAccessable("/api/Attendance2PlanRefClass/{id}"))
            {
                <TableCellButton Size="Size.ExtraSmall" Color="Color.Info" Icon="fa fa-info" Text="@WtmBlazor.Localizer["Sys.Details"]" OnClick="()=>OnDetailsClick(context)" />
            }
            @if (IsAccessable("/api/Attendance2PlanRefClass/BatchDelete"))
            {
                <PopConfirmButton Icon="fa fa-trash" Text="@WtmBlazor.Localizer["Sys.Delete"]" OnConfirm="() => OnDeleteClick(context)" Color="Color.Danger" Size="Size.ExtraSmall"
                                  Content="@WtmBlazor.Localizer["Sys.DeleteConfirm"]" CloseButtonText="@WtmBlazor.Localizer["Sys.Close"]" ConfirmButtonText="@WtmBlazor.Localizer["Sys.Delete"]" ConfirmButtonColor="Color.Danger" />
            }
        </div>
    </RowButtonTemplate>
</Table>

@code{

    private Attendance2PlanRefClassSearcher SearchModel = new Attendance2PlanRefClassSearcher();
    private Table<Attendance2PlanRefClass_View> dataTable;

    private List<SelectedItem> AllAttendance2SchemeClasss = new List<SelectedItem>();

    private List<SelectedItem> AllAttendance2PlanTimes = new List<SelectedItem>();


    protected override async Task OnInitializedAsync()
    {

        AllAttendance2SchemeClasss = await WtmBlazor.Api.CallItemsApi("/api/Attendance2PlanRefClass/GetAttendance2SchemeClasss", placeholder: WtmBlazor.Localizer["Sys.All"]);

        AllAttendance2PlanTimes = await WtmBlazor.Api.CallItemsApi("/api/Attendance2PlanRefClass/GetAttendance2PlanTimes", placeholder: WtmBlazor.Localizer["Sys.All"]);

        await base.OnInitializedAsync();
    }

    private async Task<QueryData<Attendance2PlanRefClass_View>> OnSearch(QueryPageOptions opts)
    {
        return await StartSearch<Attendance2PlanRefClass_View>("/api/Attendance2PlanRefClass/Search", SearchModel, opts);
    }

    private void DoSearch()
    {
        dataTable.QueryAsync();
    }

    private async Task OnCreateClick(IEnumerable<Attendance2PlanRefClass_View> items)
    {
        if (await OpenDialog<Create>(WtmBlazor.Localizer["Sys.Create"]) == DialogResult.Yes)
        {
            await dataTable.QueryAsync();
        }
    }

    private async Task OnEditClick(Attendance2PlanRefClass_View item)
    {
        if (await OpenDialog<Edit>(WtmBlazor.Localizer["Sys.Edit"], x => x.id == item.ID.ToString()) == DialogResult.Yes)
        {
            await dataTable.QueryAsync();
        }
    }

    private async Task OnDetailsClick(Attendance2PlanRefClass_View item)
    {
        await OpenDialog<Details>(WtmBlazor.Localizer["Sys.Details"], x => x.id == item.ID.ToString());
    }

    private async Task OnBatchDeleteClick()
    {
        if (dataTable.SelectedRows?.Any() == true)
        {
            await PostsData(dataTable.SelectedRows.Select(x => x.ID).ToList(), $"/api/Attendance2PlanRefClass/batchdelete", (s) => WtmBlazor.Localizer["Sys.BatchDeleteSuccess", s]);
            await dataTable.QueryAsync();
        }
        else
        {
            await WtmBlazor.Toast.Information(WtmBlazor.Localizer["Sys.Info"], WtmBlazor.Localizer["Sys.SelectOneRowMin"]);
        }
    }

    private async Task OnDeleteClick(Attendance2PlanRefClass_View item)
    {
        await PostsData(new List<string> { item.ID.ToString() }, $"/api/Attendance2PlanRefClass/batchdelete", (s) => "Sys.OprationSuccess");
        await dataTable.QueryAsync();
    }


    private async Task OnExportClick(IEnumerable<Attendance2PlanRefClass_View> items)
    {
        if (dataTable.SelectedRows?.Any() == true)
        {
            await Download("/api/Attendance2PlanRefClass/ExportExcelByIds", dataTable.SelectedRows.Select(x => x.ID.ToString()).ToList());
        }
        else
        {
            await Download("/api/Attendance2PlanRefClass/ExportExcel", SearchModel);
        }
    }
    private async Task OnImportClick(IEnumerable<Attendance2PlanRefClass_View> items)
    {
        if (await OpenDialog<Import>(WtmBlazor.Localizer["Sys.Import"]) == DialogResult.Yes)
        {
            await dataTable.QueryAsync();
        }
    }

}
