@page "/Attendance/Attendance2FeeCalculator/Details/{id}"
@using em_wtm.ViewModel.Attendance.Attendance2FeeCalculatorVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" >
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">

            <Display @bind-Value="@Model.Entity.DayTypeId" Lookup="@AllAttendance2DayTypes"  ShowLabel="true"/>
            <Display @bind-Value="@Model.Entity.RangeA"   ShowLabel="true"/>
            <Display @bind-Value="@Model.Entity.RangeB"   ShowLabel="true"/>
            <Display @bind-Value="@Model.Entity.RangePrice"   ShowLabel="true"/>
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Primary" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
    </div>
</ValidateForm>

@code {

    private Attendance2FeeCalculatorVM Model = null;
    private ValidateForm vform { get; set; }
    [Parameter]
    public string id { get; set; }

    private List<SelectedItem> AllAttendance2DayTypes = new List<SelectedItem>();


    protected override async Task OnInitializedAsync()
    {

        AllAttendance2DayTypes = await WtmBlazor.Api.CallItemsApi("/api/Attendance2FeeCalculator/GetAttendance2DayTypes", placeholder: WtmBlazor.Localizer["Sys.All"]);

        var rv = await WtmBlazor.Api.CallAPI<Attendance2FeeCalculatorVM>($"/api/Attendance2FeeCalculator/{id}");
        Model = rv.Data;
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
