@page "/Attendance/Attendance2PlanTime/Details/{id}"
@using em_wtm.ViewModel.Attendance.Attendance2PlanTimeVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" >
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">
        <Display @bind-Value="@Model.Entity.PlanName"   ShowLabel="true"/>
        <Display @bind-Value="@Model.Entity.DayTypeId" Lookup="@AllAttendance2DayTypes"  ShowLabel="true"/>
        <Display @bind-Value="@Model.Entity.Description"   ShowLabel="true"/>
        <Display @bind-Value="@Model.Entity.BTime" ShowLabel="true" />
        <Display @bind-Value="@Model.Entity.ETime" ShowLabel="true" />
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Primary" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
    </div>
</ValidateForm>

@code {

    private Attendance2PlanTimeVM Model = null;
    private ValidateForm vform { get; set; }
    [Parameter]
    public string id { get; set; }

    private List<SelectedItem> AllAttendance2DayTypes = new List<SelectedItem>();


    protected override async Task OnInitializedAsync()
    {

        AllAttendance2DayTypes = await WtmBlazor.Api.CallItemsApi("/api/Attendance2PlanTime/GetAttendance2DayTypes", placeholder: WtmBlazor.Localizer["Sys.All"]);

        var rv = await WtmBlazor.Api.CallAPI<Attendance2PlanTimeVM>($"/api/Attendance2PlanTime/{id}");
        Model = rv.Data;
    }

    public void OnClose()
    {
        CloseDialog();
    }

}
