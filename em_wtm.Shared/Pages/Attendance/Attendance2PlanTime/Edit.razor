@page "/Attendance/Attendance2PlanTime/Edit/{id}"
@using em_wtm.ViewModel.Attendance.Attendance2PlanTimeVMs;
@inherits BasePage

<ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit">
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">
        <BootstrapInput @bind-Value="@Model.Entity.PlanName"  />
        <Select @bind-Value="@Model.Entity.DayTypeId" Items="@AllAttendance2DayTypes" PlaceHolder="@WtmBlazor.Localizer["Sys.PleaseSelect"]"/>
        <BootstrapInput @bind-Value="@Model.Entity.Description" />
    </Row>
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">
        <div>
        <TimePickerBody @bind-Value="@Model.Entity.BTime" />
        <BootstrapInput Value="@Model.Entity.BTime.ToString("hh\\:mm\\:ss")" TValue="string" Readonly="true" DisplayText="上班时间" style="width: 180px; margin-top: 0.5rem;" />
        </div><div>
            <TimePickerBody @bind-Value="@Model.Entity.ETime" />
        <BootstrapInput Value="@Model.Entity.ETime.ToString("hh\\:mm\\:ss")" TValue="string" Readonly="true" DisplayText="下班时间"  style="width: 180px; margin-top: 0.5rem;" />
        </div>
    </Row>
    <div class="modal-footer table-modal-footer">
        <Button Color="Color.Primary" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Close"]" OnClick="OnClose" />
        <Button Color="Color.Primary" ButtonType="ButtonType.Submit" Icon="fa fa-save" Text="@WtmBlazor.Localizer["Sys.Edit"]" IsAsync="true" />
    </div>
</ValidateForm>

@code {
    private bool showBTime = false;
    private bool showETime = false;
    private TimeSpan btime, etime;
    private Attendance2PlanTimeVM Model = null;
    private ValidateForm vform { get; set; }
    [Parameter]
    public string id { get; set; }

    private List<SelectedItem> AllAttendance2DayTypes = new List<SelectedItem>();


    protected override async Task OnInitializedAsync()
    {

        AllAttendance2DayTypes = await WtmBlazor.Api.CallItemsApi("/api/Attendance2PlanTime/GetAttendance2DayTypes", placeholder: WtmBlazor.Localizer["Sys.PleaseSelect"]);

        var rv = await WtmBlazor.Api.CallAPI<Attendance2PlanTimeVM>($"/api/Attendance2PlanTime/{id}");
        Model = rv.Data;
        await base.OnInitializedAsync();
    }

    private async Task Submit(EditContext context)
    {
        await PostsForm(vform, $"/api/Attendance2PlanTime/edit", (s) => "Sys.OprationSuccess", method: HttpMethodEnum.PUT);
    }

    public void OnClose()
    {
        CloseDialog();
    }

    private async void setBtime() {
        Model.Entity.BTime = btime;
        showBTime = false;
    }
    private async void setEtime() {
        Model.Entity.ETime = etime;
        showETime = false;
    }
}
